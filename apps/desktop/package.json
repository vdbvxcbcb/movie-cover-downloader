{
  "name": "@movie-cover-downloader/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --dir ../sidecar build",
    "dev": "vite",
    "prebuild": "pnpm --dir ../sidecar build && pnpm --dir ../.. prepare:sidecar-bundle",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "pnpm test:node && pnpm test:unit",
    "test:node": "pnpm --dir ../sidecar exec tsx --test ../desktop/src/test/package-scripts.test.ts ../desktop/src/test/lib/presenters.test.ts ../desktop/src/test/lib/task-draft-input.test.ts ../desktop/src/test/lib/task-pagination.test.ts ../desktop/src/test/stores/app.test.ts ../desktop/src/test/components/queue/image-process/constants.test.ts ../desktop/src/test/components/queue/selected-photo-helpers.test.ts",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.7",
    "vue-tsc": "^2.1.10"
  }
}
